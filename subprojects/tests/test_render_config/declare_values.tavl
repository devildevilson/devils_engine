// constant_value_mirror: name, type, value(tuple<u32,u32,u32>), scale(tuple<f,f,f>),
// presets / scale_presets (vector<tuple<string, value_t>>)
{
  name = viewport
  type = screensize
}
{
  name = viewport_half
  type = screensize
  scale = [0.5, 0.5, 1.0]
}
{
  name = single_element
  type = fixed
  value = [1, 0, 0]
}
{
  name = fig_instances
  type = fixed
  value = [5000, 0, 0]
}
{
  name = fig_types
  type = fixed
  value = [5, 0, 0]
}
// Фиксированные размеры (в БАЙТАХ) host-visible буферов интерфейса. Буферы используют format c1
// (size_hint=1), поэтому итоговый размер копии = это значение. Щедрый запас: main пишет только
// использованный префикс каждый кадр (буфер команд самоописывающийся).
{
  name = ui_vertices_bytes
  type = fixed
  value = [4194304, 0, 0]
}
{
  name = ui_indices_bytes
  type = fixed
  value = [1048576, 0, 0]
}
{
  name = ui_commands_bytes
  type = fixed
  value = [65536, 0, 0]
}
{
  name = shadow_map
  type = fixed
  value = [2048, 0, 0]
  presets = [ low = [1024, 0, 0], mid = [2048, 0, 0], high = [4096, 0, 0] ]
}
