// pass_step2_mirror: name, blending(map), barriers/resources/sets/push_constants(lists),
// material, geometry, draw_group, command. Пустые контейнеры опущены = дефолт.
{
  name = draw_triangles
  material = mat1
  geometry = g1
  draw_group = dg1
  sets = [ textures ]
  command = "draw"
}
{
  name = draw_tiles
  material = tile
  geometry = g1
  draw_group = dg_tiles
  sets = [ globals, textures ]
  command = "draw"
}
{
  name = draw_actors
  material = actor
  geometry = g1
  draw_group = dg_actors
  sets = [ globals ]
  command = "draw"
}
// Интерфейс. Без draw_group: vertex/index/command буферы — обычные ресурсы, имена в команде.
// barriers дают usage: camera_buffer=uniform (для дескриптора globals), ui_vertices=vertex,
// ui_indices=index. sets: globals (UBO, set0) + textures (set1: sampled-image массив binding0 +
// sampler-пул binding1). push_constants: ui_push. Альфа-блендинг на albedo_res.
{
  name = draw_ui
  material = ui
  geometry = ui
  command = "draw_ui ui_vertices ui_indices ui_commands"
  sets = [ globals, textures ]
  push_constants = [ ui_push ]
  barriers = [ camera_buffer = uniform, ui_vertices = vertex, ui_indices = index, ui_commands = transfer_dst ]
  blending = {
    albedo_res = { enable = true, color = "src_alpha add one_minus_src_alpha", alpha = "one add one_minus_src_alpha" }
  }
}
{
  name = blit_to_swapchain
  command = "blit albedo_res swapchain_image"
}
