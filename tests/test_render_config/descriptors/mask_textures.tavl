// descriptor_mirror: name, layout[(resource,usage,sampler,stage)], texture_count/texture_sampler/texture_stage
// Второй вид asset-текстур с NEAREST-семплером — для масок стенсил-эффектов (mix/quad): те же view'ы,
// что в 'textures', но без билинейного бида на резких границах. Заполняется теми же слотами (render).
// Заглушка «все картинки linear, маски nearest»; будущая форма — отдельный тип масок (textures/mask/).
{
  name = mask_textures
  texture_count = 16
  texture_sampler = nearest
  texture_stage = fragment
}
