// resource_mirror: name, format, role, size, type, swap
{
  name = albedo_res
  format = c4
  role = gbuffer_albedo
  size = viewport
  type = frames_in_flight
  swap = per_frame
}
{
  name = swapchain_image
  format = swapchain4
  role = present
  size = viewport
  type = swapchain
  swap = swapchain
}
// Общий uniform-буфер (один на все шейдеры), host-visible, double-buffer (per_update).
// std140-раскладка (см. global_ubo.h / global_ubo в шейдерах), 2*mat4 + 4*v4 = 192 байта:
//   mat4 view_proj (мир->clip, камера) + mat4 ui_proj (пиксели окна->clip, UI) +
//   vec4 misc (x=screen_w, y=screen_h, z=sdf_px_range, w=reserved).
// role=upload — host пишет напрямую. ВНИМАНИЕ: usage_mask собирается из ссылок в ШАГАХ —
// пока ни один шаг не подцепил буфер как uniform, usage=0 (createBuffer-варнинг ожидаем;
// уйдёт на шаге 4, когда UI-шаг сошлётся на camera_buffer и дескриптор его свяжет).
{
  name = camera_buffer
  format = mat4mat4v4v4v4v4
  role = upload
  size = single_element
  type = doublebuffer
  swap = per_update
}
// Буферы интерфейса (visage). Host-visible (role=upload), doublebuffer/per_update — пишем в
// неиспользуемую копию, не дожидаясь fence. format c1 => размер копии = <bytes value>.
// vertices/indices биндятся в draw_ui (через barriers получают vertex/index usage); commands
// читается на CPU (.mapped) и интерпретируется как [uint32 count][gui_draw_command_t...].
{
  name = ui_vertices
  format = c1
  role = upload
  size = ui_vertices_bytes
  type = doublebuffer
  swap = per_update
}
{
  name = ui_indices
  format = c1
  role = upload
  size = ui_indices_bytes
  type = doublebuffer
  swap = per_update
}
{
  name = ui_commands
  format = c1
  role = upload
  size = ui_commands_bytes
  type = doublebuffer
  swap = per_update
}
